{
  "name": "liplo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx server.ts",
    "dev:next": "next dev -p 7050",
    "dev:ws": "echo 'Realtime is included in pnpm dev. Starting the combined dev server...' && pnpm dev",
    "build": "prisma generate && next build",
    "start": "NODE_ENV=production tsx server.ts",
    "start:next": "next start -p 7050",
    "start:ws": "echo 'Realtime is included in pnpm start. Starting the combined production server...' && pnpm start",
    "lint": "eslint .",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-wc": "^0.9.12",
    "@prisma/client": "^6.8.2",
    "@radix-ui/react-slot": "^1.1.1",
    "@xyflow/react": "^12.10.2",
    "bcryptjs": "^2.4.3",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "mysql2": "^3.11.5",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-moveable": "^0.56.0",
    "react-selecto": "^1.26.3",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^2.5.5",
    "tiktok-live-connector": "^1.2.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "prisma": "^6.8.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.15.1"
}
